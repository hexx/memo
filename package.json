{
  "name": "org-memo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"wrangler dev\" \"vite\"",
    "dev:web": "vite",
    "dev:api": "wrangler dev",
    "build": "vite build",
    "preview": "vite preview",
    "icons:generate": "node scripts/generate-icons.mjs",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply org-memo-db",
    "db:migrate:local": "wrangler d1 migrations apply org-memo-db --local",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.81.1",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/react-query": "^5.60.0",
    "@tanstack/react-router": "^1.80.0",
    "@tiptap/react": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "lucide-react": "^1.23.0",
    "org-toolkit": "git+https://github.com/hexx/org-toolkit.git#3968dbe",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^3.6.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241000.0",
    "@tanstack/router-devtools": "^1.80.0",
    "@tanstack/router-vite-plugin": "^1.80.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "better-sqlite3": "^12.11.1",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.28.0",
    "oxlint": "^1.72.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.9",
    "wrangler": "^3.84.0"
  }
}
