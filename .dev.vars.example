# ローカル開発用の環境変数テンプレート。
# このファイルを .dev.vars としてコピーし、実際の値を埋めてください。
# .dev.vars は .gitignore に含まれており、シークレットがコミットされることはありません。
#
#   cp .dev.vars.example .dev.vars
#
# 本番環境では `wrangler secret put AI_API_KEY` で設定してください。

AI_API_KEY=your-api-key-here
AI_BASE_URL=https://opencode.ai/zen/go/v1
AI_MODEL=deepseek-v4-flash
